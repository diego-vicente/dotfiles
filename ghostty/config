theme = catppuccin-mocha.conf
font-thicken = true

# Configure for macOS
shell-integration = fish
desktop-notifications = true
macos-option-as-alt = true

# notify-on-command-finish = unfocused
# notify-on-command-finish-after = 30s

# Unbind and rebind the new tab
# keybind = cmd+t=unbind
# keybind = cmd+shift+t=new_tab

# Unbind the directions to move between panes and tabs in Ghostty
# GOTCHA: cmd+h has to be unbind at the system level in:
#   > Settings > Keyboard > Keyboard Shortcuts...
#keybind = cmd+h=unbind
#keybind = cmd+j=unbind
#keybind = cmd+k=unbind
#keybind = cmd+l=unbind

keybind = cmd+h=goto_split:left
keybind = cmd+j=goto_split:bottom
keybind = cmd+k=goto_split:top
keybind = cmd+l=goto_split:right

keybind = shift+enter=text:\n

keybind = global:cmd+semicolon=toggle_quick_terminal
quick-terminal-position = center
quick-terminal-size = 50%,50%
